# ─── COPIÁ ESTO EN LAS VARIABLES DE RAILWAY ───────────────────
# NO subas este archivo a GitHub. Es solo de referencia.

# ── n8n Config ──────────────────────────────────────────────────
# N8N_HOST → Lo completás DESPUÉS de hacer el deploy (Railway te da la URL)
N8N_HOST=tu-proyecto.up.railway.app

# Clave de encriptación → Generá una random de 32 caracteres
# Podés usar: https://www.random.org/strings/ o cualquier generador
N8N_ENCRYPTION_KEY=pon_aqui_una_clave_random_de_32_caracteres

# Usuario y contraseña para entrar a n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=pon_aqui_una_password_segura

# ── Base de datos (Supabase) ─────────────────────────────────────
# Estos datos los encontrás en Supabase → Settings → Database
DB_POSTGRESDB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=tu_password_de_supabase

# ── Gmail ────────────────────────────────────────────────────────
# GMAIL_USER → tu email de Gmail
# GMAIL_APP_PASSWORD → NO es tu password normal
#   Generalo en: Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
GMAIL_USER=tu_email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
